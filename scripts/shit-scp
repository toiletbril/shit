#!/bin/env shit
# vi: ft=bash
# copies current shit shell binary to a remote server and puts it in PATH.
set -eu -o pipefail
HOST="${1:-}"
test -z "${HOST-}" -o -z "${SHIT-}" && \
  printf "%s <host>\ncopies current shit shell binary to a remote server and puts it in PATH\nrun this inside shit shell\n" "$(basename "$0")" >&2 && exit 1
set -x
scp "$(which "$SHIT")" "$HOST":'shit'
ssh "$HOST" <<'EOF'
_find_writable_path_dir() {
  for F in $(echo "$PATH'" | sed -E 's/:/\n/g')
  do
    case "$F" in
      *sbin*);;
      *) test -w "$F" && echo "$F" && break;;
    esac
  done
}
chmod +x ./shit
WRITABLE_DIR="$(_find_writable_path_dir)"
test -n "$WRITABLE_DIR" && mv shit "$WRITABLE_DIR"
EOF
