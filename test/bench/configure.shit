#!/bin/bash
# A configure-style benchmark built to show what shit's default-mood optimizer
# eliminates that bash must run every time. The script is deterministic and
# uses only constructs bash runs identically, so a run doubles as a
# correctness check, while the hot loops are packed with constant-guarded dead
# branches, dead loops, and constant arithmetic. shit proves each of these at
# parse time and runs a collapsed loop body, where bash evaluates every guard,
# folds no arithmetic, and walks every dead branch on every pass.

set -u

# The work multiplier. A larger value lengthens every loop.
SCALE=${SCALE:-40}

# Build-style toggles assigned once and never reassigned, the shape a real
# configure run carries. The optimizer proves every guard that reads them dead
# at parse time, while bash tests each one on every pass through the hot loops.
CONFIG_TRACE=0
CONFIG_PROFILE=0
CONFIG_PARANOID=0
CONFIG_DEBUG=0
CONFIG_RELEASE=1

CHECKS=0
SUM=0

# The dense pass. Each iteration carries a stack of guards the optimizer reads
# as constant-false and removes whole, plus constant arithmetic it folds, so
# shit runs a near-empty body while bash evaluates every test and every
# expansion on every one of the SCALE * 200 iterations.
i=0
limit=$((SCALE * 200))
while [ "$i" -lt "$limit" ]; do
  # Dead constant guards. Each then-branch is unreachable, proven at parse, so
  # shit drops it entirely while bash runs the test command every pass.
  if [ 0 -eq 1 ]; then SUM=$((SUM + 999)); fi
  if [ "$CONFIG_TRACE" -eq 1 ]; then SUM=$((SUM + 1)); fi
  if [ "$CONFIG_PROFILE" -eq 1 ]; then SUM=$((SUM + 2)); fi
  if [ "$CONFIG_PARANOID" -eq 1 ]; then SUM=$((SUM + 3)); fi
  if [ "$CONFIG_DEBUG" -eq 1 ]; then SUM=$((SUM + 4)); fi
  if false; then SUM=$((SUM + 5)); fi

  # A dead loop the optimizer removes whole, where bash evaluates the condition.
  while false; do SUM=$((SUM + 6)); done
  until true; do SUM=$((SUM + 7)); done

  # A C-style for whose condition folds to a constant zero never iterates, so
  # the optimizer removes the whole loop while bash evaluates the header.
  for ((d = 0; 0; d++)); do SUM=$((SUM + 8)); done

  # An if whose only branch is constant-false and which has no else body is a
  # proven no-op the optimizer eliminates whole.
  if false; then SUM=$((SUM + 9)); fi

  # Algebraic identities that fold to a constant, a zero multiply and a name
  # minus itself, so the addition contributes nothing on every pass.
  SUM=$((SUM + i * 0))
  SUM=$((SUM + i - i))

  # The live tail, a constant fold and one real increment. shit folds the
  # constant arithmetic at parse, bash recomputes it every pass.
  SUM=$((SUM + 2 * 3 + 4 - 1))
  CHECKS=$((CHECKS + 1))
  i=$((i + 1))
done

# A second pass guarded as a whole by a constant-false configuration, so the
# optimizer removes the entire loop while bash evaluates the guard once and
# bash that does enter on a true build still pays the per-pass tests below.
if [ "$CONFIG_DEBUG" -eq 1 ]; then
  j=0
  while [ "$j" -lt "$limit" ]; do
    SUM=$((SUM + j))
    j=$((j + 1))
  done
fi

# The release path runs, the one live configuration. Its body is still salted
# with dead guards the optimizer strips.
if [ "$CONFIG_RELEASE" -eq 1 ]; then
  k=0
  rlimit=$((SCALE * 100))
  while [ "$k" -lt "$rlimit" ]; do
    if [ 1 -eq 0 ]; then SUM=$((SUM + 100)); fi
    if [ "$CONFIG_TRACE" -ne 0 ]; then SUM=$((SUM + 200)); fi
    SUM=$((SUM + 8 / 2 - 3))
    CHECKS=$((CHECKS + 1))
    k=$((k + 1))
  done
fi

echo "checks=$CHECKS"
echo "sum=$SUM"
echo "release=$CONFIG_RELEASE trace=$CONFIG_TRACE"
