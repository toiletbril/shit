#!/bin/env shit
set -e
false && echo never-and
echo after-and
! true
echo after-neg
false || true
echo after-or-ok
! false
echo after-neg-ok
if ( set -e; true && false ); then echo sub-ok; else echo sub-exited; fi
if ( set -e; false || false ); then echo or-ok; else echo or-exited; fi
if ( set -e; false ); then echo bare-ok; else echo bare-exited; fi
if ( set -e; ! false ); then echo neg-ok; else echo neg-exited; fi
echo done
