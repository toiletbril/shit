#!/bin/env shit
# A printf -v binds a shell variable, so a constant recorded before it must not
# be inlined into a later arithmetic read. The optimizer once treated printf as
# environment-neutral and printed the stale 5 here, where the value printf wrote
# must win.
x=5
printf -v x 99
echo $((x + 0))

# A plain printf writes only its output, so a constant recorded before it is
# still safe to read after.
y=7
printf '%s\n' hello
echo $((y + 1))
