#!/bin/env shit
# Triggers in a function that is never called, so the analysis warns while
# nothing runs.
lint_only() {
  egrep pattern file
  fgrep word file
  expr 1 + 2
  let counter=counter+1
  echo "$(date)"
  ps | grep init
  ls | grep conf
  grep needle file | wc -l
  local outside=here
  [ $? -eq 0 ] && echo ok
  local declared=$(date)
}
echo done
