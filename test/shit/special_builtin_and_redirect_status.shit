# A prefix assignment before a special builtin persists after the command in the
# default mood, matching POSIX, while the same prefix before a regular command
# stays temporary. A redirection that cannot open its target fails the command
# with status 2 and the located error is printed, and the shell continues.
x=before
x=after :
echo "special=[$x]"
y=keep
y=temp true
echo "regular=[$y]"
foo=bar export baz=1
echo "export_prefix=[$foo][$baz]"
cat < /no/such/directory/file 2>/dev/null
echo "redirect_status=$?"
echo still_here
