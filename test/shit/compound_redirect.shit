#!/bin/env shit
(echo hi) > /tmp/shit_compound_redir.txt
cat /tmp/shit_compound_redir.txt
echo back
{ echo a; echo b; } > /tmp/shit_compound_redir.txt
awk 'END{print NR}' /tmp/shit_compound_redir.txt
for n in 1 2 3; do echo $n; done > /tmp/shit_compound_redir.txt
