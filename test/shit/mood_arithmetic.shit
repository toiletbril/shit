#!/bin/env shit
# Bash arithmetic extensions run in the default mood.
echo $((2 ** 10))
echo $((-2 ** 2))
echo $((2 ** 3 ** 2))
echo $((0xff + 16#10))
echo $((010 + 2#101))
echo $((36#z))
echo $((6 & 3 | 8 ^ 1))
echo $((5 > 3 ? 10 : 20))
n=5
((n += 3, n *= 2))
echo "n=$n"
status=ok
((0)) || status=zero-false
echo "$status"
sum=0
for ((i = 1; i <= 5; i++)); do sum=$((sum + i)); done
echo "sum=$sum"
fact=1
let "fact = 1"
for ((i = 1; i <= 5; i++)); do let "fact *= i"; done
echo "fact=$fact"
