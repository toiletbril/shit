#!/bin/env shit
# A recorded constant survives across a read-only command, so a later
# arithmetic reference still inlines it. echo, true, and a read-only coreutil
# such as basename never write a shell variable, so the constant table stays
# valid across them.
n=10
echo first
true
echo $((n + 5))
basename /tmp/whatever >/dev/null
echo $((n * 2))
