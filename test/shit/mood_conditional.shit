#!/bin/env shit
# Bash [[ ]] conditionals work in the default strict mood, not only bash mode.
[[ "configure.sh" == *.sh ]] && echo glob-yes
[[ "a*b" == "a*b" ]] && echo quoted-literal
[[ -n "x" && ( -z "" || "a" == "a" ) ]] && echo grouped
[[ 10 -gt 5 && 3 -le 3 ]] && echo numeric
if [[ "v12.3" =~ ^v([0-9]+)\.([0-9]+)$ ]]; then
    echo "rematch ${BASH_REMATCH[1]} ${BASH_REMATCH[2]} whole=${BASH_REMATCH[0]}"
fi
x=set
[[ -v x ]] && echo has-x
[[ -v missing ]] || echo no-missing
