[ "(" = "(" ]; echo "paren_eq=$?"
[ "(" ]; echo "paren_single=$?"
[ ")" ]; echo "rparen_single=$?"
[ "(" = ")" ]; echo "paren_ne=$?"
[ a \< b ]; echo "lt_true=$?"
[ b \< a ]; echo "lt_false=$?"
[ a \> b ]; echo "gt_false=$?"
[ b \> a ]; echo "gt_true=$?"
[ 10 \< 9 ]; echo "byte_lt=$?"
[ abc \< abd ]; echo "abc_lt_abd=$?"
[ \( a = a \) ]; echo "group_eq=$?"
[ \( a = a \) -a -n x ]; echo "group_and=$?"
