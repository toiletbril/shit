# A quoted or escaped metacharacter inside a bracket class is a literal member,
# not a class operator, and the matcher reads the same per-byte active mask the
# rest of glob expansion uses. A high byte at or above 0x80 compares as itself,
# so a range whose bound is a non-ASCII byte still matches.

# A quoted ] inside the class is a member, so the class is { a, ], b }. The ] no
# longer closes the class early.
case ] in [a"]"b]) echo bracket_close_hit;; *) echo bracket_close_miss;; esac
case b in [a"]"b]) echo bracket_b_hit;; *) echo bracket_b_miss;; esac
case x in [a"]"b]) echo bracket_x_hit;; *) echo bracket_x_miss;; esac

# A quoted - is a literal member, not a range operator, so the class is
# { a, -, z } and matches only those three bytes.
case - in [a"-"z]) echo dash_dash_hit;; *) echo dash_dash_miss;; esac
case m in [a"-"z]) echo dash_m_hit;; *) echo dash_m_miss;; esac
case a in [a"-"z]) echo dash_a_hit;; *) echo dash_a_miss;; esac

# A quoted leading ! is a literal member, not a negation.
case "!" in [a"!"b]) echo bang_member_hit;; *) echo bang_member_miss;; esac
case c in [a"!"b]) echo bang_c_hit;; *) echo bang_c_miss;; esac

# A quoted pattern variable matches its value literally, while an unquoted one
# keeps the metacharacter live.
star="*"
case foo in "$star") echo quoted_star_hit;; *) echo quoted_star_miss;; esac
case foo in $star) echo unquoted_star_hit;; *) echo unquoted_star_miss;; esac

# A range whose upper bound is a non-ASCII byte matches an ASCII byte that falls
# inside it. With a signed comparison the high byte would read as negative and
# the range would be empty.
case b in [a-ÿ]) echo highrange_b_hit;; *) echo highrange_b_miss;; esac
case A in [a-ÿ]) echo highrange_A_hit;; *) echo highrange_A_miss;; esac
case = in [!a-ÿ]) echo neg_highrange_hit;; *) echo neg_highrange_miss;; esac
