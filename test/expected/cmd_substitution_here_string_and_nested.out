  DoubleQuoted "part value tail"
]
[Word
  Unquoted "tar="
  CommandSubstitution " printf '%s\n' "$line" | sed -e 's/^.* \([^ ]*x\) .*$/\1/' <<<"$line" "
]
[Word
  Unquoted "echo"
]
[Word
  DoubleQuoted "tar="
