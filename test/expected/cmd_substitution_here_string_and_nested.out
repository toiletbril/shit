[CompoundList]
  [CompoundListCondition, None]
    [Assign x=$( cat <<< "payload" )]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "x=$x"]
  [CompoundListCondition, None]
    [Assign empty=]
  [CompoundListCondition, None]
    [Assign y=$( cat <<<"$empty" )]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "y=$y"]
  [CompoundListCondition, None]
    [Assign z=$( echo "$( echo nested )" -- "$x" )]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "z=$z"]
  [CompoundListCondition, None]
    [Assign w=$( echo "$( printf '%s\n' "'")")]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "w=$w"]
  [CompoundListCondition, None]
    [Assign line=part value tail]
  [CompoundListCondition, None]
    [Assign tar=$( printf '%s\n' "$line" | sed -e 's/^.* \([^ ]*x\) .*$/\1/' <<<"$line" )]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "tar=$tar"]
[Word
  Unquoted "x="
  CommandSubstitution " cat <<< "payload" "
]
[Word
  Unquoted "echo"
]
[Word
  DoubleQuoted "x="
  Variable "x"
]
