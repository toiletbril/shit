  [CompoundListCondition, None]
    [SimpleCommand "set" "--" "$a[@]+"${b[*]}""]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "n=$#"]
  [CompoundListCondition, None]
    [SimpleCommand "unset" "IFS"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "a-b"]
