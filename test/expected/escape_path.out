[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "**"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "~**"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "\\"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "data/*/*"]
  [CompoundListCondition, None]
    [SimpleCommand "test" "-e" "~/*"]
  [CompoundListCondition, &&]
    [SimpleCommand "no" "such" "file"]
  [CompoundListCondition, None]
    [SimpleCommand "test" "-d" "~"]
  [CompoundListCondition, &&]
    [SimpleCommand "echo" "no" "such" "dir"]
[Escape Bitmap
  00000110 00000000 11100000 00000110 00000000 00000101 00000000 00000010 00000000 00000000 00000000 00100000 
]
**
~**
\\
data/*/*
[Code 1]
