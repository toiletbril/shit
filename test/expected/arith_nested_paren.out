  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( 2 + $((3 * 4)) ))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( $(echo 5)$(echo 0) ))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( (1 + 2) * 3 ))"]
