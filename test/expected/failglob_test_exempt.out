[CompoundList]
  [CompoundListCondition, None]
    [Assign d=$(mktemp -d)]
  [CompoundListCondition, None]
    [SimpleCommand "cd" "$d"]
  [CompoundListCondition, None]
    [SimpleCommand "[" "-e" "*.zzz" "]"]
  [CompoundListCondition, &&]
    [SimpleCommand "echo" "bracket-exists"]
  [CompoundListCondition, ||]
    [SimpleCommand "echo" "bracket-no-match"]
  [CompoundListCondition, None]
    [SimpleCommand "test" "-e" "*.zzz"]
  [CompoundListCondition, &&]
    [SimpleCommand "echo" "test-exists"]
  [CompoundListCondition, ||]
    [SimpleCommand "echo" "test-no-match"]
  [CompoundListCondition, None]
    [SimpleCommand "touch" "real.zzz"]
  [CompoundListCondition, None]
    [SimpleCommand "[" "-e" "*.zzz" "]"]
  [CompoundListCondition, &&]
    [SimpleCommand "echo" "bracket-exists"]
  [CompoundListCondition, ||]
    [SimpleCommand "echo" "bracket-no-match"]
  [CompoundListCondition, None]
    [SimpleCommand "test" "-e" "*.zzz"]
  [CompoundListCondition, &&]
    [SimpleCommand "echo" "test-exists"]
  [CompoundListCondition, ||]
    [SimpleCommand "echo" "test-no-match"]
  [CompoundListCondition, None]
    [SimpleCommand "cd" "/"]
  [CompoundListCondition, None]
    [SimpleCommand "rm" "-r" "$d"]
[Word
  Unquoted "d="
  CommandSubstitution "mktemp -d"
]
