[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "trap" "echo PARENT" "EXIT"]
  [CompoundListCondition, None]
    [Subshell]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "trap" "echo SUB" "EXIT"]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "in-sub"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "after-sub"]
  [CompoundListCondition, None]
    [Subshell]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "plain-sub"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "after-plain"]
  [CompoundListCondition, None]
    [Subshell]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "exit" "3"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "exit-rc=$?"]
  [CompoundListCondition, None]
    [Assign v=$( trap "echo CSUB" EXIT; echo captured )]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "got=$v"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "done"]
