[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "set" "--" "-a" "val" "-bc" "arg"]
  [CompoundListCondition, None]
    [WhileLoop]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "getopts" "a:bc" "opt"]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "opt=$opt arg=$OPTARG"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "rest=$1 ind=$OPTIND"]
  [CompoundListCondition, None]
    [SimpleCommand "set" "--" "-x"]
  [CompoundListCondition, None]
    [SimpleCommand "getopts" ":a:" "o"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "silent=$o arg=$OPTARG"]
