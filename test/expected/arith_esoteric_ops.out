  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( 0 ? 20 : 30 ))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( 3 & 5 | 2 ^ 1 ))"]
