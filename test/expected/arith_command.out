  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( 2 * (3+4) ))"]
  [CompoundListCondition, None]
    [Assign i=10]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(( i-- ))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$i"]
