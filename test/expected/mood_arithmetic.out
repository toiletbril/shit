[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((2 ** 10))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((-2 ** 2))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((2 ** 3 ** 2))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((0xff + 16#10))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((010 + 2#101))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((36#z))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((6 & 3 | 8 ^ 1))"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((5 > 3 ? 10 : 20))"]
  [CompoundListCondition, None]
    [Assign n=5]
  [CompoundListCondition, None]
    [ArithmeticCommand "n += 3, n *= 2"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "n=$n"]
  [CompoundListCondition, None]
    [Assign status=ok]
  [CompoundListCondition, None]
    [ArithmeticCommand "0"]
  [CompoundListCondition, ||]
    [Assign status=zero-false]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$status"]
  [CompoundListCondition, None]
    [Assign sum=0]
  [CompoundListCondition, None]
    [CStyleForLoop "i = 1; i <= 5; i++"]
      [CompoundList]
        [CompoundListCondition, None]
          [Assign sum=$((sum + i))]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "sum=$sum"]
  [CompoundListCondition, None]
    [Assign fact=1]
  [CompoundListCondition, None]
    [SimpleCommand "let" "fact = 1"]
  [CompoundListCondition, None]
    [CStyleForLoop "i = 1; i <= 5; i++"]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "let" "fact *= i"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "fact=$fact"]
