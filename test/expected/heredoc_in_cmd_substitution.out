[CompoundList]
  [CompoundListCondition, None]
    [Assign x=$(cat <<EOF
body
EOF
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$x"]
  [CompoundListCondition, None]
    [Assign y=$(cat <<EOF
first line
second line
third line
EOF
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$y"]
  [CompoundListCondition, None]
    [ForLoop "i"]
      [CompoundList]
        [CompoundListCondition, None]
          [Assign z=$(cat <<EOF
iteration $i
EOF
)]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "$z"]
[Word
  Unquoted "x="
  CommandSubstitution "cat <<EOF
body
EOF
"
]
