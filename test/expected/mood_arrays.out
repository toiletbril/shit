[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$a[@]"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$a[*]"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$#a[@]"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$a[2]"]
  [CompoundListCondition, None]
    [SimpleCommand]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$#a[@] $a[-1]"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$a[@]:1:2"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$a[*]: -2"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$!a[@]"]
  [CompoundListCondition, None]
    [Assign a[10]=far]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$!a[@]"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$#a[@]"]
  [CompoundListCondition, None]
    [SimpleCommand]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "empty $#b[@]"]
  [CompoundListCondition, None]
    [ForLoop "x"]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "elem $x"]
