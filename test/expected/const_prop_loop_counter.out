[CompoundList]
  [CompoundListCondition, None]
    [Assign count=0]
  [CompoundListCondition, None]
    [ForLoop "item"]
      [CompoundList]
        [CompoundListCondition, None]
          [Assign count=$((count + 1))]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "count=$count"]
  [CompoundListCondition, None]
    [Assign i=0]
  [CompoundListCondition, None]
    [UntilLoop]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "[" "$i" "-ge" "3" "]"]
      [CompoundList]
        [CompoundListCondition, None]
          [Assign i=$((i + 1))]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "i=$i"]
[Word
  Unquoted "count=0"
