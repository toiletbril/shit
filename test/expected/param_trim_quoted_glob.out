[CompoundList]
  [CompoundListCondition, None]
    [Assign x=a*c]
  [CompoundListCondition, None]
    [SimpleCommand "printf" "%s\n" "$x%"*c""]
  [CompoundListCondition, None]
    [Assign x=abc]
  [CompoundListCondition, None]
    [Assign p=*]
  [CompoundListCondition, None]
    [SimpleCommand "printf" "%s\n" "$x##"$p""]
  [CompoundListCondition, None]
    [Assign x=a*c]
  [CompoundListCondition, None]
    [SimpleCommand "printf" "[%s]\n" "$x#a\*"]
  [CompoundListCondition, None]
    [Assign x=aXc]
  [CompoundListCondition, None]
    [SimpleCommand "printf" "[%s]\n" "$x#a\X"]
  [CompoundListCondition, None]
    [Assign x=abc]
  [CompoundListCondition, None]
    [SimpleCommand "printf" "[%s]\n" "$x#a*"]
  [CompoundListCondition, None]
    [Assign v=a*b*c]
  [CompoundListCondition, None]
    [SimpleCommand "printf" "[%s]\n" "$v%%"*"*"]
