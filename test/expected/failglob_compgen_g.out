[CompoundList]
  [CompoundListCondition, None]
    [Assign d=$(mktemp -d)]
  [CompoundListCondition, None]
    [SimpleCommand "cd" "$d"]
  [CompoundListCondition, None]
    [SimpleCommand "touch" "real.txt"]
  [CompoundListCondition, None]
    [SimpleCommand "compgen" "-G" "*.txt"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "glob-match=$?"]
  [CompoundListCondition, None]
    [SimpleCommand "compgen" "-G" "*.zzz"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "glob-miss=$?"]
  [CompoundListCondition, None]
    [SimpleCommand "compgen" "-G" "real.txt"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "plain-exists=$?"]
  [CompoundListCondition, None]
    [SimpleCommand "compgen" "-G" "missing.txt"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "plain-missing=$?"]
  [CompoundListCondition, None]
    [IfClause]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "compgen" "-G" "*.txt"]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "found"]
  [CompoundListCondition, None]
    [SimpleCommand "cd" "/"]
  [CompoundListCondition, None]
    [SimpleCommand "rm" "-r" "$d"]
[Word
  Unquoted "d="
  CommandSubstitution "mktemp -d"
