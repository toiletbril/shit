[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "simple=${ echo one;  }"]
  [CompoundListCondition, None]
    [SimpleCommand "${ persist=42;  }"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "persist=$persist"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "nested=${ echo $(echo inner);  }"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "split" "${ echo a b c;  }"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "joined=[${ echo x y z;  }]"]
