[CompoundList]
  [CompoundListCondition, None]
    [Assign HOME=/testhome]
  [CompoundListCondition, None]
    [Assign x=$(cat <<EOF
body
EOF
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$x"]
  [CompoundListCondition, None]
    [Assign y=$(cat <<'EOF'
a " b
EOF
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$y"]
  [CompoundListCondition, None]
    [Assign z=$(cat <<EOF
$HOME
EOF
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$z"]
  [CompoundListCondition, None]
    [Assign w=$(echo pre; cat <<EOF
mid
EOF
echo post)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$w"]
  [CompoundListCondition, None]
    [Assign t=$(cat <<'EOF'
has `backticks` and $vars
EOF
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$t"]
[Word
  Unquoted "HOME=/testhome"
]
