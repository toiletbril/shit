[CompoundList]
  [CompoundListCondition, None]
    [Assign a=outer]
  [CompoundListCondition, None]
    [ForLoop "a"]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "in: $a"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "after restore: [$a]"]
  [CompoundListCondition, None]
    [ForLoop "fresh"]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand ":"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "fresh leaked: [$fresh:-no]"]
