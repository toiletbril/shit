[CompoundList]
  [CompoundListCondition, None]
    [Assign result=$(echo hello  # a ) comment
)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$result"]
  [CompoundListCondition, None]
    [Assign mid=$(echo foo#bar)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$mid"]
  [CompoundListCondition, None]
    [Assign quoted=$(echo "a # ) b")]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$quoted"]
  [CompoundListCondition, None]
    [Assign nested=$(echo $(echo inner # ) cmt
))]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$nested"]
