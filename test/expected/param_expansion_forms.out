[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "set" "--" "a" "b" "c"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$@"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$#"]
  [CompoundListCondition, None]
    [Assign IFS=:]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$*"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$999:-fallback"]
  [CompoundListCondition, None]
    [Assign x=hello]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$x#he" "$x%lo" "$#x" "$x:1:3"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$nope:-def" "$x:+yes"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "marker$!end"]
