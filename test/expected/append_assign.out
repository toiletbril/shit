[CompoundList]
  [CompoundListCondition, None]
    [Assign x=a]
  [CompoundListCondition, None]
    [Assign x+=bc]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$x"]
  [CompoundListCondition, None]
    [Assign n+=z]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$n"]
