[CompoundList]
  [CompoundListCondition, None]
    [Assign n=10]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "first"]
  [CompoundListCondition, None]
    [SimpleCommand "true"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((n + 5))"]
  [CompoundListCondition, None]
    [SimpleCommand "basename" "/tmp/whatever"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((n * 2))"]
