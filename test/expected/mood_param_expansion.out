[CompoundList]
  [CompoundListCondition, None]
    [Assign word=configure-script-runner]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word%%-*"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word##*-"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word//-/_"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word/-/_"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word/#configure/setup"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word/%runner/walker"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word^^"]
  [CompoundListCondition, None]
    [Assign upper=$word^^]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$upper,,"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word~"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word:10:6"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$word: -6"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$#word"]
  [CompoundListCondition, None]
    [Assign ref=word]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$!ref"]
  [CompoundListCondition, None]
    [Assign prefix_one=1]
  [CompoundListCondition, None]
    [Assign prefix_two=2]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$!prefix_*"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$undef:-fallback" "$word:+present"]
