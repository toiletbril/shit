[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(echo hi)"]
  [CompoundListCondition, None]
    [Assign x=$(echo abc)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$x"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(echo q)"]
  [CompoundListCondition, None]
    [CaseClause]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "echo" "matched"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$((echo y) 2>/dev/null)"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(echo "a b")"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "`echo no`"]
  [CompoundListCondition, None]
    [Assign foo=bar]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$(echo $foo)"]
