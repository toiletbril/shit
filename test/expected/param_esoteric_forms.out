[CompoundList]
  [CompoundListCondition, None]
    [Assign v=hello]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$v:0:-2"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$v: -3:2"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$v:(-3)"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$v:10"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$v//l/L"]
  [CompoundListCondition, None]
    [Assign w=a.b.c]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$w%.*"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "$w##*."]
[Word
  Unquoted "v=hello"
]
[Word
  Unquoted "echo"
]
