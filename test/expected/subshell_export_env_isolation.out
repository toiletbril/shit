[CompoundList]
  [CompoundListCondition, None]
    [SimpleCommand "export" "V=parent"]
  [CompoundListCondition, None]
    [Subshell]
      [CompoundList]
        [CompoundListCondition, None]
          [Assign V=child]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "1:$V"]
  [CompoundListCondition, None]
    [Assign r=$(V=sub; echo x)]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "2:$V $r"]
  [CompoundListCondition, None]
    [SimpleCommand "export" "W=keep"]
  [CompoundListCondition, None]
    [Subshell]
      [CompoundList]
        [CompoundListCondition, None]
          [SimpleCommand "unset" "W"]
  [CompoundListCondition, None]
    [SimpleCommand "echo" "3:[$W]"]
